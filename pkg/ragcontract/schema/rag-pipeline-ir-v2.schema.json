{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "rag-pipeline-ir/v2",
	"type": "object",
	"additionalProperties": false,
	"required": ["schemaVersion", "inputs", "nodes", "outputs"],
	"properties": {
		"schemaVersion": { "const": "rag-pipeline-ir/v2" },
		"inputs": { "type": "array", "items": { "$ref": "#/$defs/input" } },
		"nodes": { "type": "array", "items": { "$ref": "#/$defs/node" } },
		"outputs": { "type": "array", "items": { "$ref": "#/$defs/output" } },
		"seedPolicy": { "type": "object" }
	},
	"$defs": {
		"operator": {
			"type": "object",
			"additionalProperties": false,
			"required": ["kind", "version"],
			"properties": { "kind": { "type": "string" }, "version": { "pattern": "^v[1-9][0-9]*$" } }
		},
		"portRef": {
			"type": "object",
			"additionalProperties": false,
			"required": ["nodeId", "port"],
			"properties": { "nodeId": { "type": "string" }, "port": { "type": "string" } }
		},
		"input": {
			"type": "object",
			"additionalProperties": false,
			"required": ["id", "kind", "bindingMode"],
			"properties": {
				"id": { "type": "string" },
				"kind": { "type": "string" },
				"bindingMode": { "enum": ["artifact", "request", "dataset"] },
				"artifactRole": { "type": "string" },
				"manifestSchema": { "type": "string" },
				"digest": { "type": "string" }
			}
		},
		"binding": {
			"type": "object",
			"additionalProperties": false,
			"required": ["port", "from"],
			"properties": { "port": { "type": "string" }, "from": { "$ref": "#/$defs/portRef" } }
		},
		"node": {
			"type": "object",
			"additionalProperties": false,
			"required": ["id", "operator", "inputs", "config"],
			"properties": {
				"id": { "type": "string" },
				"operator": { "$ref": "#/$defs/operator" },
				"inputs": { "type": "array", "items": { "$ref": "#/$defs/binding" } },
				"config": { "type": "object" },
				"order": { "type": "integer" }
			}
		},
		"output": {
			"type": "object",
			"additionalProperties": false,
			"required": ["name", "kind", "from"],
			"properties": {
				"name": { "type": "string" },
				"kind": { "type": "string" },
				"from": { "$ref": "#/$defs/portRef" }
			}
		}
	}
}
