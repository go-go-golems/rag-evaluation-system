{
	"schemaVersion": "rag-retrieval-spec/v1",
	"name": "ttc-raw-hybrid",
	"dataset": {
		"split": "development"
	},
	"representations": [
		{
			"name": "raw",
			"kind": "rawChunks"
		}
	],
	"retrieval": {
		"filter": {},
		"channels": [
			{
				"name": "lexical",
				"backend": "bm25",
				"representation": "raw",
				"topK": 50,
				"filter": {}
			},
			{
				"name": "semantic",
				"backend": "vector",
				"representation": "raw",
				"topK": 50,
				"filter": {}
			}
		],
		"fusion": {
			"kind": "rrf",
			"rankConstant": 60,
			"weights": {
				"semantic": 1.25
			}
		},
		"collapse": "document",
		"results": 10
	},
	"metrics": {
		"relevanceAt": "2_SUBSTANTIAL",
		"recallAt": [10],
		"precisionAt": [1, 3, 10],
		"ndcgAt": [10],
		"mrr": true
	},
	"tags": {
		"corpus": "ttc",
		"status": "candidate"
	}
}
