											"maxWidth": "5ch"
										},
										{
											"cell": {
												"action": {
													"event": "server",
													"kind": "server",
													"name": "course.agenda.edit",
													"payload": {
														"direction": "down",
														"id": {
															"kind": "path",
															"path": "rows"
														}
													}
												},
												"kind": "actionButton",
