								},
								"subtitle": {
									"fallback": "—",
									"field": "amount",
									"format": "integer",
									"kind": "number"
								},
								"title": {
									"field": "title",
									"kind": "field"
								}
							},
							"cards": [
								{
									"id": "d1",
									"owner": "Mira",
									"stage": "lead",
									"title": "Acme",
									"value": "$12k"
								},
								{
									"id": "d2",
									"owner": "Noah",
									"stage": "won",
									"title": "Globex",
									"value": "$25k"
								}
							],
							"columnField": "stageId",
							"columns": [
								{
									"accent": null,
									"header": "Lead",
									"id": "lead"
								},
								{
									"accent": null,
									"header": "Won",
									"id": "won"
								}
							],
							"getCardId": {
								"field": "id"
							},
							"styleSet": {
								"id": "crm-stages",
								"styles": {
									"lead": {
										"fill": "color-mix(in srgb, var(--mac-text-dim) 20%, var(--mac-surface))",
										"labelColor": "var(--mac-text)",
										"line": "var(--mac-text-dim)"
									},
									"lost": {
										"fill": "color-mix(in srgb, var(--mac-accent-2) 30%, var(--mac-surface))",
										"labelColor": "var(--mac-text)",
										"line": "var(--mac-accent-2)"
									},
									"negotiation": {
										"fill": "color-mix(in srgb, var(--mac-accent-2) 24%, var(--mac-surface))",
										"labelColor": "var(--mac-text)",
										"line": "var(--mac-accent-2)"
									},
									"proposal": {
										"fill": "color-mix(in srgb, var(--mac-amber) 26%, var(--mac-surface))",
										"labelColor": "var(--mac-text)",
										"line": "var(--mac-amber)"
									},
									"qualified": {
										"fill": "color-mix(in srgb, var(--mac-accent) 22%, var(--mac-surface))",
										"labelColor": "var(--mac-text)",
										"line": "var(--mac-accent)"
									},
									"won": {
										"fill": "color-mix(in srgb, var(--mac-green) 26%, var(--mac-surface))",
										"labelColor": "var(--mac-text)",
										"line": "var(--mac-green)"
									}
								}
							}
						},
						"type": "BoardEngine"
					}
				],
				"kind": "component",
				"props": {
					"density": "flush",
